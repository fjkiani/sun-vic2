# Copy to .env and fill. All keys stay SERVER-SIDE (Netlify env). None ship in the browser bundle.

# ───── Supabase ─────
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ───── LLM providers ─────
COHERE_API_KEY=
OPENROUTER_API_KEY=
GEMMA_API_KEY=

# ───── Email ─────
RESEND_API_KEY=
RESEND_FROM_EMAIL=Sunvic Construction <no-reply@sunvicnj.com>

# ───── Public URL for signed links ─────
PUBLIC_SITE_URL=https://sunvicnj.com

# ───── Shared secret for public signed URLs ─────
SESSION_JWT_SECRET=

# ───── VITE (browser) — only two safe values ─────
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
