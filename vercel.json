{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/documents/[[...path]].js": { "maxDuration": 30 },
    "api/agent/oneshot.js":         { "maxDuration": 60 },
    "api/agent/chat.js":            { "maxDuration": 60 },
    "api/threads/[[...path]].js":   { "maxDuration": 60 }
  }
}
