{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/api/threads/:sub*",   "destination": "/api/threads?sub=:sub*" },
    { "source": "/api/documents/:sub*", "destination": "/api/documents?sub=:sub*" },
    { "source": "/api/projects/:sub*",  "destination": "/api/projects?sub=:sub*" },
    { "source": "/((?!api/).*)",        "destination": "/index.html" }
  ],
  "functions": {
    "api/documents/index.js": { "maxDuration": 30 },
    "api/agent/oneshot.js":   { "maxDuration": 60 },
    "api/agent/chat.js":      { "maxDuration": 60 },
    "api/threads/index.js":   { "maxDuration": 60 }
  }
}
