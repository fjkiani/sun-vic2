{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/documents/[id]/pdf.js":   { "maxDuration": 30, "memory": 1024 },
    "api/documents/[id]/email.js": { "maxDuration": 20, "memory": 512 },
    "api/agent/oneshot.js":        { "maxDuration": 60, "memory": 1024 },
    "api/agent/chat.js":           { "maxDuration": 60, "memory": 1024 }
  }
}
